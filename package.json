{
  "name": "internship-scraper",
  "version": "1.0.0",
  "description": "Daily scraper for internship and co-op listings",
  "main": "dist/index.js",
  "scripts": {
    "scrape": "ts-node src/index.ts",
    "sort": "ts-node src/sorter.ts",
    "rank": "ts-node src/ranker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "csv-writer": "^1.6.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.5",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
